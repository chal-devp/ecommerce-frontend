const express = require('express');
const cors = require('cors');
require('dotenv').config();
const connectDB = require('../db');
const productRoutes = require('./productRoutes'); // Import your routes
const Order = require('../models/Order'); // Import the model we just created


const app = express();
// Middleware
app.use(cors());
app.use(express.json());

// Connect to Database
connectDB(); 

// Use Product Routes
app.use('/api', productRoutes); // This makes routes available at /api/products

// Simple test route
app.get('/', (req, res) => {
  res.send('E-commerce API is running successfully!');
});

const PORT = process.env.PORT || 5000;

app.listen(PORT, () => {
  console.log(`🚀 Server is running on http://localhost:${PORT}`);
});
app.use(express.json()); // Allows Express to understand JSON data from React

// The POST route to save a new order
app.post('/api/orders', async (req, res) => {
  try {
    // 1. Extract the data sent from the React frontend
    const { items, totalAmount } = req.body;

    // 2. Basic Validation: check if the cart is empty
    if (!items || items.length === 0) {
      return res.status(400).json({ message: 'Cart is empty' });
    }

    // 3. Create a new order object based on our Mongoose model
    const newOrder = new Order({
      items: items,
      totalAmount: totalAmount
    });

    // 4. Save it to MongoDB
    const savedOrder = await newOrder.save();

    // 5. Send a success message back to React
    res.status(201).json({ 
      message: 'Order placed successfully!', 
      order: savedOrder 
    });

  } catch (error) {
    console.error('Error saving order:', error);
    res.status(500).json({ message: 'Server error while placing order' });
  }
});